{
  "name": "eurlex-mcp-server",
  "version": "2.2.0",
  "description": "MCP Server for EU law via EUR-Lex Cellar API — search, fetch, and analyze EU regulations, directives, and court decisions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "eurlex-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start:http": "node dist/http.js",
    "dev:http": "tsx src/http.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "pnpm run typecheck && pnpm run typecheck:tests && pnpm run lint && pnpm run format:check && pnpm run test",
    "inspect": "pnpm dlx @modelcontextprotocol/inspector node dist/index.js",
    "test:coverage": "vitest run --coverage",
    "prebuild": "pnpm run typecheck",
    "prepublishOnly": "pnpm run check && pnpm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "eurlex",
    "eur-lex",
    "eu-law",
    "european-union",
    "legal",
    "cellar-api",
    "sparql"
  ],
  "author": "philrox <phil@resultsbymagic.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Honeyfield-Org/eurlex-mcp-server.git"
  },
  "homepage": "https://github.com/Honeyfield-Org/eurlex-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Honeyfield-Org/eurlex-mcp-server/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.2.7"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.3",
      "esbuild": ">=0.25.0",
      "postcss": ">=8.5.10"
    }
  }
}
